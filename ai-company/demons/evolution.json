    "identify_redundant_agents",
    "propose_agent_merges",
    "suggest_new_specialist_agents",
    "recommend_team_restructures",
    "track_agent_evolution_over_time"
  ],
  "actions": [
    "propose_new_agent",
    "recommend_agent_retirement",
    "suggest_team_merge",
    "generate_evolution_report",
    "escalate_to_chro"
