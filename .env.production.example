# =============================================================================
# Fitsi IA — Production Environment Variables (Docker Compose level)
# =============================================================================
# Copy this file:  cp .env.production.example .env
# Then fill in ALL values before running docker compose.
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=fitsiai
POSTGRES_PASSWORD=          # REQUIRED — generate with: openssl rand -base64 32
POSTGRES_DB=fitsiai_db

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=             # REQUIRED — generate with: openssl rand -base64 32

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
BACKEND_PORT=8000
GUNICORN_WORKERS=4          # Recommended: 2 * CPU cores + 1

# ---------------------------------------------------------------------------
# Docker Image (when using pre-built images from GHCR)
# ---------------------------------------------------------------------------
# IMAGE_TAG=latest
