# ──────────────────────────────────────────────────────────────────────────────
# Calendar App — Backend Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Sync PostgreSQL URL used by Alembic migrations.
# When running via docker-compose this is overridden to use the service name.
DATABASE_URL=postgresql://calapp:calapp_secret@localhost:5432/calendar_db

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

ALGORITHM=HS256

# Minutes before an access token expires (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Separate secret for refresh tokens — must differ from SECRET_KEY
REFRESH_SECRET_KEY=change-me-to-another-random-64-char-hex-string

# Days before a refresh token expires (default: 30)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Redis ─────────────────────────────────────────────────────────────────────
# When running via docker-compose this is overridden to use the service name.
REDIS_URL=redis://localhost:6379/0

# Maximum number of connections in the Redis connection pool
REDIS_MAX_CONNECTIONS=50

# ── Database connection pool ──────────────────────────────────────────────────
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
# Recycle connections after this many seconds (1800 = 30 min)
DB_POOL_RECYCLE=1800

# ── Apple Sign-In ─────────────────────────────────────────────────────────────
# Bundle ID of your iOS app registered in Apple Developer portal
APPLE_CLIENT_ID=com.example.calendarapp

# 10-character Team ID from Apple Developer account
APPLE_TEAM_ID=XXXXXXXXXX

# Key ID of the Sign in with Apple private key
APPLE_KEY_ID=XXXXXXXXXX

# Contents of the .p8 private key file (newlines replaced with \n)
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nXXXXXXXXXX\n-----END PRIVATE KEY-----

# ── Google Sign-In ────────────────────────────────────────────────────────────
# OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=1234567890-abcdefghijklmnop.apps.googleusercontent.com

# ── OpenAI (AI Food Scan) ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Use ["*"] for development only.
# In production list exact origins, e.g.: ["https://app.example.com"]
CORS_ORIGINS=["*"]
