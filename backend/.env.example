# =============================================================================
# Fitsi IA Backend — Environment Variables
# =============================================================================
# Copy this file:  cp .env.example .env
# Then fill in the values marked REQUIRED.
# =============================================================================

# ---------------------------------------------------------------------------
# Environment (development | staging | production)
# ---------------------------------------------------------------------------
ENV=development

# ---------------------------------------------------------------------------
# Database (PostgreSQL)  [REQUIRED]
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://calapp:calapp_secret@localhost:5432/calendar_db
# For Docker Compose the URL is overridden to point at the 'db' service.
# In production, use an RDS/Cloud SQL connection string.

# ---------------------------------------------------------------------------
# Redis  [REQUIRED]
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Auth Secrets  [REQUIRED]
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
SECRET_KEY=
REFRESH_SECRET_KEY=

# ---------------------------------------------------------------------------
# CORS (JSON array of allowed origins)
# In production, set to your real domain(s). Never use "*" in production.
# ---------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]

# ---------------------------------------------------------------------------
# Apple OAuth (requires Apple Developer Account — $99/year)
# ---------------------------------------------------------------------------
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Google OAuth (requires Google Cloud Console project — free)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=

# ---------------------------------------------------------------------------
# OpenAI — AI Food Scanning (pay-per-use)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Anthropic — AI Food Scanning fallback (pay-per-use, optional)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# AI Provider: claude, openai, auto (fallback Claude -> OpenAI -> mock)
# ---------------------------------------------------------------------------
AI_PROVIDER=auto

# ---------------------------------------------------------------------------
# Supabase (Database + Storage + Auth)
# See docs/SUPABASE-SETUP.md for step-by-step instructions
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ---------------------------------------------------------------------------
# S3 / Cloudflare R2 — Image Storage (legacy, use Supabase Storage instead)
# ---------------------------------------------------------------------------
S3_BUCKET_NAME=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# For Cloudflare R2, also set:
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# ---------------------------------------------------------------------------
# Sentry — Error Tracking (optional in dev)
# ---------------------------------------------------------------------------
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Gunicorn tuning (production only — ignored by uvicorn in dev)
# ---------------------------------------------------------------------------
# GUNICORN_WORKERS=4
# GUNICORN_TIMEOUT=120
# GUNICORN_MAX_REQUESTS=2000
# GUNICORN_LOG_LEVEL=info
