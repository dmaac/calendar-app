# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/calendarapp
# DATABASE_URL_ASYNC is derived automatically if not set

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT / Security ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-32-char-secret
REFRESH_SECRET_KEY=change-me-to-another-random-32-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Apple Sign In ───────────────────────────────────────────────────────────
APPLE_CLIENT_ID=com.yourapp.bundleid
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
# Paste the full PEM private key (with header/footer, newlines as \n)
APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nXXXXX\n-----END PRIVATE KEY-----

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# ─── OpenAI (AI Food Scan) ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:8081,exp://localhost:8081
