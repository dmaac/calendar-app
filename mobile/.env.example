# =============================================================================
# Fitsi Mobile — Environment Variables
# =============================================================================
# Copy this file:  cp .env.example .env
# Expo reads EXPO_PUBLIC_* variables at build time.
# =============================================================================

# ---------------------------------------------------------------------------
# API URL — points to the backend
# ---------------------------------------------------------------------------
# Local development (adjust IP for physical device testing):
EXPO_PUBLIC_API_URL=http://localhost:8000
# Staging:
# EXPO_PUBLIC_API_URL=https://api-staging.fitsi.app
# Production:
# EXPO_PUBLIC_API_URL=https://api.fitsi.app

# ---------------------------------------------------------------------------
# Google OAuth Client IDs (from Google Cloud Console)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ---------------------------------------------------------------------------
# RevenueCat — In-App Purchases (optional in dev)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# ---------------------------------------------------------------------------
# Sentry — Error Tracking (optional in dev)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
EXPO_PUBLIC_ENABLE_AI_SCAN=true
EXPO_PUBLIC_ENABLE_PAYWALL=true
