# ──────────────────────────────────────────────────────────────────────────────
# Calendar App — Mobile (Expo) Environment Variables
# Copy this file to .env and fill in real values before running.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the JS bundle and
# visible to the client — never put secrets here.
# ──────────────────────────────────────────────────────────────────────────────

# URL of the FastAPI backend. Use your machine's LAN IP when testing on a
# physical device (e.g. http://192.168.1.100:8000).
EXPO_PUBLIC_API_URL=http://localhost:8000

# Google OAuth client IDs — create these in Google Cloud Console under
# "Credentials" for each platform.
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
