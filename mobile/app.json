{
  "expo": {
    "name": "Fitsi AI",
    "slug": "fitsiai",
    "scheme": "fitsiai",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4285F4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fitsiai.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Fitsi AI necesita acceso a la camara para escanear alimentos con IA.",
        "NSPhotoLibraryUsageDescription": "Fitsi AI necesita acceso a tus fotos para seleccionar imagenes de alimentos.",
        "NSHealthShareUsageDescription": "Fitsi AI usa tus datos de salud para personalizar tu plan nutricional y calcular calorias quemadas.",
        "NSHealthUpdateUsageDescription": "Fitsi AI registra tu ingesta nutricional y agua en Apple Health."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4285F4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.fitsiai.app",
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-localization",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-apple-authentication"
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4285F4"
        }
      ],
      [
        "react-native-purchases",
        {
          "ios": {
            "usesStoreKit2JWS": true
          }
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/YOUR_PROJECT_ID_HERE"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_PROJECT_ID_HERE"
      }
    },
    "owner": "fitsiai"
  }
}
